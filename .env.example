# ─── 배포 도메인 (참고) ───────────────────────────
# Vercel: https://markettinghowa-5.vercel.app
# Render: https://markettinghowa-5.onrender.com
# Supabase: https://oljekyqhsqawqmxzpkeg.supabase.co

# ═══════════════════════════════════════════════════
# Vercel Environment Variables (권장 변수명)
# next.config.mjs 가 SUPABASE_* → NEXT_PUBLIC_* 로 빌드 시 전달
# ═══════════════════════════════════════════════════
# SUPABASE_URL=https://oljekyqhsqawqmxzpkeg.supabase.co
# SUPABASE_KEY=sb_publishable_...   (anon / publishable 키)
# API_URL=https://markettinghowa-5.onrender.com   (선택, 없으면 코드 기본값)
#
# 또는 기존 이름 그대로:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=

# ═══════════════════════════════════════════════════
# Render Environment Variables (권장 변수명)
# backend/app/core/config.py 가 읽음
# ═══════════════════════════════════════════════════
# SUPABASE_URL=https://oljekyqhsqawqmxzpkeg.supabase.co
# SUPABASE_KEY=...   (서버용: service_role 권장, anon/publishable 도 가능)
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# (기타 .env.example 이전 목록과 동일)

# 로컬: backend/.env 에 위와 동일한 이름으로 값 입력
