# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=https://markettinghowa-5.onrender.com

# ═══════════════════════════════════════════════════
# Render (백엔드) — Environment에 아래 변수명으로 추가
# 코드는 backend/app/core/config.py 기준으로 읽음
# ═══════════════════════════════════════════════════
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# OPENAI_API_MODEL=gpt-4o
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# BAIDU_INDEX_API_KEY=
# HS_CODE_API_KEY=
# UNCOMTRADE_API_KEY=
# HS_PERCENTAGE_API_KEY=
# KOTRA_NEWS_API_KEY=
# BREAKING_NEWS_API_KEY=
# REMOVE_BG_API_KEY=
# PORTER_GROK_API_KEY=
# PORTER_API_URL=
# TEXT_MODEL=gpt-4o
# IMAGE_MODEL=gpt-image-1

# 로컬 개발 시 backend/.env 에 위 변수 값을 채워 사용
